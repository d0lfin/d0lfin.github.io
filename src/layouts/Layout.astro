---
import SiteFooter from "../components/SiteFooter.astro";
import SiteHeader from "../components/SiteHeader.astro";
import { getSiteUrl, toAbsoluteUrl } from "../lib/site";

interface Props {
	pageTitle?: string;
	description?: string;
	canonicalPath?: string;
	ogImage?: string;
	ogType?: "website" | "article";
	noIndex?: boolean;
}

const {
	pageTitle = "Alexey Emelin",
	description = "Personal blog and gallery.",
	canonicalPath,
	ogImage,
	ogType = "website",
	noIndex = false,
} = Astro.props;

const site = getSiteUrl(Astro.site);
const canonicalUrl = toAbsoluteUrl(canonicalPath ?? Astro.url.pathname, site);
const resolvedOgImage = toAbsoluteUrl(ogImage ?? "/og-default.svg", site);
const pathname = Astro.url.pathname;
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="icon" href="/favicon.ico" />
		<link rel="preconnect" href="https://fonts.googleapis.com" />
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
		<link
			rel="stylesheet"
			href="https://fonts.googleapis.com/css2?family=Fraunces:opsz,wght@9..144,400;9..144,500;9..144,600&family=Manrope:wght@400;500;600;700&display=swap"
		/>
		<meta name="generator" content={Astro.generator} />
		<meta name="description" content={description} />
		<link rel="canonical" href={canonicalUrl} />
		<meta property="og:site_name" content="Alexey Emelin" />
		<meta property="og:type" content={ogType} />
		<meta property="og:title" content={pageTitle} />
		<meta property="og:description" content={description} />
		<meta property="og:url" content={canonicalUrl} />
		<meta property="og:image" content={resolvedOgImage} />
		<meta name="twitter:card" content="summary_large_image" />
		<meta name="twitter:title" content={pageTitle} />
		<meta name="twitter:description" content={description} />
		<meta name="twitter:image" content={resolvedOgImage} />
		{noIndex && <meta name="robots" content="noindex,nofollow" />}
		<title>{pageTitle}</title>
	</head>
	<body>
		<div class="site-bg"></div>
		<div class="site-shell">
			<SiteHeader currentPath={pathname} />
			<main class="site-main">
				<slot />
			</main>
			<SiteFooter />
		</div>
	</body>
</html>

<style is:global>
	:root {
		--bg: #f4f1e8;
		--paper: #fffdf8;
		--paper-soft: #fcf8ef;
		--ink: #1f1f1c;
		--muted: #68645c;
		--line: #d8cfbe;
		--accent: #2d7669;
		--accent-soft: #20574f;
		--shadow-soft: 0 22px 55px rgba(18, 25, 20, 0.08);
		--radius-lg: 20px;
		--radius-md: 13px;
		--radius-sm: 9px;
		--content-width: 1120px;
		color: var(--ink);
		background: var(--bg);
	}

	*,
	*::before,
	*::after {
		box-sizing: border-box;
	}

	html,
	body {
		margin: 0;
		width: 100%;
	}

	body {
		font-family: "Manrope", "Segoe UI", sans-serif;
		color: var(--ink);
		line-height: 1.68;
	}

	.site-bg {
		position: fixed;
		inset: 0;
		background:
			radial-gradient(1300px 540px at 76% -14%, rgba(45, 118, 105, 0.16), transparent 58%),
			radial-gradient(950px 420px at 2% -4%, rgba(157, 100, 63, 0.15), transparent 62%),
			repeating-linear-gradient(
				90deg,
				rgba(255, 255, 255, 0.05) 0 1px,
				rgba(255, 255, 255, 0) 1px 13px
			),
			var(--bg);
		z-index: -1;
	}

	.site-shell {
		max-width: var(--content-width);
		margin: 0 auto;
		padding: 20px clamp(16px, 2.9vw, 42px) 56px;
	}

	.site-header {
		display: flex;
		flex-wrap: wrap;
		align-items: baseline;
		justify-content: space-between;
		gap: 16px 24px;
		padding: 8px 0 20px;
		border-bottom: 1px solid var(--line);
	}

	.brand {
		text-decoration: none;
		color: inherit;
		display: inline-flex;
		flex-direction: column;
		gap: 2px;
	}

	.brand-top {
		font-family: "Fraunces", "Times New Roman", serif;
		font-size: clamp(1.56rem, 3.25vw, 2.35rem);
		letter-spacing: 0.01em;
		line-height: 1;
	}

	.brand-bottom {
		font-size: 0.73rem;
		letter-spacing: 0.18em;
		text-transform: uppercase;
		color: var(--muted);
	}

	.site-nav {
		display: flex;
		flex-wrap: wrap;
		gap: 8px;
	}

	.nav-link {
		color: var(--muted);
		text-decoration: none;
		font-size: 0.83rem;
		letter-spacing: 0.1em;
		text-transform: uppercase;
		padding: 8px 10px;
		border-radius: 999px;
		border: 1px solid transparent;
		transition: border-color 0.2s ease, color 0.2s ease, background-color 0.2s ease;
	}

	.nav-link:hover,
	.nav-link:focus-visible {
		border-color: var(--line);
		color: var(--ink);
		outline: none;
	}

	.nav-link.is-active {
		color: var(--ink);
		border-color: var(--line);
		background: rgba(255, 255, 255, 0.54);
	}

	.site-main {
		padding: clamp(20px, 3.8vw, 48px) 0;
	}

	.site-main > * + * {
		margin-top: clamp(24px, 3.6vw, 40px);
	}

	.site-footer {
		padding-top: 22px;
		border-top: 1px solid var(--line);
		color: var(--muted);
		font-size: 0.9rem;
		display: flex;
		flex-wrap: wrap;
		gap: 6px 16px;
		justify-content: space-between;
	}

	.site-footer p {
		margin: 0;
	}

	h1,
	h2,
	h3,
	h4 {
		font-family: "Fraunces", "Times New Roman", serif;
		letter-spacing: 0.01em;
		line-height: 1.14;
		margin: 0 0 0.62em;
	}

	h1 {
		font-size: clamp(2.05rem, 4.5vw, 3.7rem);
	}

	h2 {
		font-size: clamp(1.5rem, 2.6vw, 2.35rem);
	}

	h3 {
		font-size: clamp(1.22rem, 1.95vw, 1.6rem);
	}

	p {
		margin: 0 0 1rem;
	}

	a {
		color: var(--accent);
		text-underline-offset: 2px;
	}

	a:hover {
		color: var(--accent-soft);
	}

	a:focus-visible,
	button:focus-visible {
		outline: 2px solid color-mix(in srgb, var(--accent) 65%, black);
		outline-offset: 3px;
		border-radius: 4px;
	}

	img {
		max-width: 100%;
		height: auto;
	}

	code,
	pre {
		font-family: "SFMono-Regular", Menlo, Monaco, Consolas, "Liberation Mono", "Courier New", monospace;
	}

	code {
		font-size: 0.92em;
		padding: 0.16em 0.35em;
		border-radius: 6px;
		background: rgba(255, 255, 255, 0.68);
		overflow-wrap: anywhere;
	}

	pre {
		overflow-x: auto;
		padding: 1rem;
		border-radius: var(--radius-md);
		background: #221f1a;
		color: #f0ede6;
	}

	pre code {
		background: transparent;
		padding: 0;
		color: inherit;
	}

	.page-intro {
		margin-bottom: clamp(18px, 3vw, 34px);
	}

	.page-kicker {
		font-size: 0.76rem;
		letter-spacing: 0.17em;
		text-transform: uppercase;
		color: var(--muted);
		margin-bottom: 10px;
	}

	.page-lead {
		font-size: clamp(1.06rem, 1.74vw, 1.25rem);
		max-width: 65ch;
		color: var(--muted);
	}

	.breadcrumbs {
		display: flex;
		flex-wrap: wrap;
		gap: 7px;
		align-items: center;
		font-size: 0.75rem;
		letter-spacing: 0.12em;
		text-transform: uppercase;
		color: var(--muted);
		margin: 0 0 12px;
	}

	.breadcrumbs a {
		color: inherit;
		text-decoration: none;
		border-bottom: 1px solid transparent;
	}

	.breadcrumbs a:hover,
	.breadcrumbs a:focus-visible {
		border-bottom-color: currentColor;
	}

	.section-block {
		margin-top: clamp(18px, 3.1vw, 34px);
	}

	.section-head {
		display: flex;
		justify-content: space-between;
		gap: 10px 16px;
		flex-wrap: wrap;
		align-items: flex-end;
		margin-bottom: 14px;
	}

	.section-head h2,
	.section-head h3 {
		margin-bottom: 0;
	}

	.mag-grid {
		display: grid;
		grid-template-columns: repeat(auto-fill, minmax(220px, 1fr));
		gap: 16px;
	}

	.mag-list {
		display: grid;
		gap: 14px;
	}

	.photo-card,
	.post-card {
		display: block;
		background: color-mix(in srgb, var(--paper) 82%, white);
		border: 1px solid var(--line);
		border-radius: var(--radius-md);
		padding: 11px;
		text-decoration: none;
		color: inherit;
		transition: transform 0.25s ease, box-shadow 0.25s ease, border-color 0.25s ease;
	}

	.photo-card:hover,
	.post-card:hover {
		transform: translateY(-2px);
		box-shadow: var(--shadow-soft);
		border-color: color-mix(in srgb, var(--line) 68%, var(--accent) 32%);
	}

	.photo-card img {
		width: 100%;
		aspect-ratio: 4 / 3;
		object-fit: cover;
		border-radius: var(--radius-sm);
		display: block;
	}

	.photo-card-title,
	.post-card-title {
		display: block;
		margin-top: 9px;
		font-family: "Fraunces", "Times New Roman", serif;
		font-size: 1.05rem;
		line-height: 1.2;
	}

	.post-card-title a {
		color: inherit;
		text-decoration: none;
	}

	.post-card-title a:hover,
	.post-card-title a:focus-visible {
		text-decoration: underline;
	}

	.meta-line {
		display: flex;
		flex-wrap: wrap;
		gap: 8px 12px;
		align-items: center;
		color: var(--muted);
		font-size: 0.88rem;
	}

	.chip-row {
		display: flex;
		flex-wrap: wrap;
		gap: 8px;
	}

	.chip {
		display: inline-flex;
		align-items: center;
		padding: 6px 10px;
		font-size: 0.74rem;
		line-height: 1;
		letter-spacing: 0.08em;
		text-transform: uppercase;
		border: 1px solid var(--line);
		border-radius: 999px;
		text-decoration: none;
		color: var(--muted);
		background: rgba(255, 255, 255, 0.46);
		transition: border-color 0.2s ease, color 0.2s ease, background-color 0.2s ease;
	}

	.chip:hover,
	.chip:focus-visible {
		border-color: color-mix(in srgb, var(--line) 58%, var(--accent) 42%);
		color: var(--ink);
		outline: none;
	}

	.chip.is-current {
		border-color: color-mix(in srgb, var(--line) 55%, var(--accent) 45%);
		color: var(--ink);
		background: rgba(255, 255, 255, 0.72);
	}

	.chip.is-disabled {
		opacity: 0.5;
		pointer-events: none;
	}

	.pager {
		display: flex;
		flex-wrap: wrap;
		gap: 10px;
		align-items: center;
	}

	.card-panel {
		background: color-mix(in srgb, var(--paper) 84%, white);
		border: 1px solid var(--line);
		border-radius: var(--radius-lg);
		padding: clamp(15px, 2.4vw, 23px);
	}

	.prose {
		max-width: 72ch;
	}

	.prose > :last-child {
		margin-bottom: 0;
	}

	.prose :where(h2, h3, h4) {
		margin-top: 1.4em;
	}

	.prose :where(ul, ol) {
		padding-left: 1.2rem;
	}

	.prose :where(li + li) {
		margin-top: 0.45rem;
	}

	.prose blockquote {
		margin: 1.3rem 0;
		padding: 0.5rem 0 0.5rem 1rem;
		border-left: 3px solid color-mix(in srgb, var(--line) 62%, var(--accent) 38%);
		color: var(--muted);
	}

	.prose img {
		border-radius: var(--radius-md);
	}

	[data-animate] {
		animation: fade-up 0.62s ease both;
	}

	@keyframes fade-up {
		from {
			opacity: 0;
			transform: translateY(6px);
		}
		to {
			opacity: 1;
			transform: translateY(0);
		}
	}

	@media (max-width: 720px) {
		.site-footer {
			flex-direction: column;
		}
	}
</style>
