---
import SiteFooter from "../components/SiteFooter.astro";
import SiteHeader from "../components/SiteHeader.astro";
import { getSiteUrl, toAbsoluteUrl } from "../lib/site";

interface Props {
	pageTitle?: string;
	description?: string;
	canonicalPath?: string;
	ogImage?: string;
	ogType?: "website" | "article";
	noIndex?: boolean;
}

const {
	pageTitle = "Alexey Emelin",
	description = "Personal blog and gallery.",
	canonicalPath,
	ogImage,
	ogType = "website",
	noIndex = false,
} = Astro.props;

const site = getSiteUrl(Astro.site);
const canonicalUrl = toAbsoluteUrl(canonicalPath ?? Astro.url.pathname, site);
const resolvedOgImage = toAbsoluteUrl(ogImage ?? "/og-default.svg", site);
const pathname = Astro.url.pathname;
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="icon" href="/favicon.ico" />
		<link rel="preconnect" href="https://fonts.googleapis.com" />
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
		<link
			rel="stylesheet"
			href="https://fonts.googleapis.com/css2?family=Fraunces:opsz,wght@9..144,400;9..144,500;9..144,600&family=Manrope:wght@400;500;600;700&display=swap"
		/>
		<meta name="generator" content={Astro.generator} />
		<meta name="description" content={description} />
		<link rel="canonical" href={canonicalUrl} />
		<meta property="og:site_name" content="Alexey Emelin" />
		<meta property="og:type" content={ogType} />
		<meta property="og:title" content={pageTitle} />
		<meta property="og:description" content={description} />
		<meta property="og:url" content={canonicalUrl} />
		<meta property="og:image" content={resolvedOgImage} />
		<meta name="twitter:card" content="summary_large_image" />
		<meta name="twitter:title" content={pageTitle} />
		<meta name="twitter:description" content={description} />
		<meta name="twitter:image" content={resolvedOgImage} />
		{noIndex && <meta name="robots" content="noindex,nofollow" />}
		<title>{pageTitle}</title>
		<script is:inline>
			const getThemePreference = () => {
				if (typeof localStorage !== 'undefined' && localStorage.getItem('theme')) {
					return localStorage.getItem('theme');
				}
				return window.matchMedia('(prefers-color-scheme: light)').matches ? 'light' : 'dark';
			};
			const isDark = getThemePreference() === 'dark';
			document.documentElement.classList[isDark ? 'add' : 'remove']('dark');
            document.documentElement.setAttribute('data-theme', isDark ? 'dark' : 'light');
		</script>
	</head>
	<body>
		<div class="site-bg"></div>
		<div class="site-shell">
			<SiteHeader currentPath={pathname} />
			<main class="site-main">
				<slot />
			</main>
			<SiteFooter />
		</div>
	</body>
</html>

<style is:global>
	:root {
		/* Light Theme Colors */
		--bg: #f4f1e8;
		--paper: #fffdf8;
		--paper-soft: #fcf8ef;
		--ink: #1f1f1c;
		--muted: #68645c;
		--line: #d8cfbe;
		--accent: #2d7669;
		--accent-soft: #20574f;
		--shadow-soft: 0 22px 55px rgba(18, 25, 20, 0.08);
        --hero-gradient: radial-gradient(1300px 540px at 76% -14%, rgba(45, 118, 105, 0.16), transparent 58%), radial-gradient(950px 420px at 2% -4%, rgba(157, 100, 63, 0.15), transparent 62%);

		--radius-lg: 20px;
		--radius-md: 13px;
		--radius-sm: 9px;
		--content-width: 1120px;
		color: var(--ink);
		background: var(--bg);
	}

    :root[data-theme="dark"] {
        /* Dark Theme Colors */
		--bg: #0a0a0a;
		--paper: #141414;
		--paper-soft: #1a1a1a;
		--ink: #e6e6e6;
		--muted: #a1a1a1;
		--line: #333333;
		--accent: #4fb5a3;
		--accent-soft: #63c9b7;
		--shadow-soft: 0 22px 55px rgba(0, 0, 0, 0.4);
        --hero-gradient: radial-gradient(1300px 540px at 76% -14%, rgba(45, 118, 105, 0.25), transparent 58%), radial-gradient(950px 420px at 2% -4%, rgba(157, 100, 63, 0.2), transparent 62%);
    }

	*,
	*::before,
	*::after {
		box-sizing: border-box;
	}

	html,
	body {
		margin: 0;
		width: 100%;
	}

	body {
		font-family: "Manrope", "Segoe UI", sans-serif;
		color: var(--ink);
		line-height: 1.68;
	}

	.site-bg {
		position: fixed;
		inset: 0;
		background:
			var(--hero-gradient),
			repeating-linear-gradient(
				90deg,
				rgba(128, 128, 128, 0.05) 0 1px,
				rgba(128, 128, 128, 0) 1px 13px
			),
			var(--bg);
		z-index: -1;
        transition: background-color 0.4s ease, background-image 0.4s ease;
	}

	.site-shell {
		max-width: var(--content-width);
		margin: 0 auto;
		padding: 20px clamp(16px, 2.9vw, 42px) 56px;
	}

	.site-header {
		position: sticky;
		top: 0;
		z-index: 100;
		display: flex;
		flex-wrap: wrap;
		align-items: center;
		justify-content: space-between;
		gap: 16px 24px;
		padding: 16px 24px;
		margin: 0 -24px; /* offset shell padding if needed or adjust shell */
		background: color-mix(in srgb, var(--bg) 80%, transparent);
		backdrop-filter: blur(12px);
		-webkit-backdrop-filter: blur(12px);
		border-bottom: 1px solid color-mix(in srgb, var(--line) 50%, transparent);
		transition: background-color 0.4s ease, border-color 0.4s ease;
	}

	.brand {
		text-decoration: none;
		color: inherit;
		display: inline-flex;
		flex-direction: column;
		gap: 2px;
	}

	.brand-top {
		font-family: "Fraunces", "Times New Roman", serif;
		font-size: clamp(1.56rem, 3.25vw, 2.35rem);
		letter-spacing: 0.01em;
		line-height: 1;
	}

	.brand-bottom {
		font-size: 0.73rem;
		letter-spacing: 0.18em;
		text-transform: uppercase;
		color: var(--muted);
	}

	.site-nav {
		display: flex;
		flex-wrap: wrap;
		gap: 8px;
	}

	.nav-link {
		color: var(--muted);
		text-decoration: none;
		font-size: 0.83rem;
		letter-spacing: 0.1em;
		text-transform: uppercase;
		padding: 8px 10px;
		border-radius: 999px;
		border: 1px solid transparent;
		transition: border-color 0.2s ease, color 0.2s ease, background-color 0.2s ease;
	}

	.nav-link:hover,
	.nav-link:focus-visible {
		border-color: var(--line);
		color: var(--ink);
		outline: none;
	}

	.nav-link.is-active {
		color: var(--ink);
		background: color-mix(in srgb, var(--ink) 8%, transparent);
	}

	.site-main {
		padding: clamp(32px, 5vw, 64px) 0;
	}

	.site-main > * + * {
		margin-top: clamp(40px, 6vw, 64px);
	}

	.site-footer {
		padding-top: 32px;
		border-top: 1px solid var(--line);
		color: var(--muted);
		font-size: 0.95rem;
		display: flex;
		flex-wrap: wrap;
		gap: 12px 24px;
		justify-content: space-between;
	}

	.site-footer p {
		margin: 0;
	}

	h1,
	h2,
	h3,
	h4 {
		font-family: "Fraunces", "Times New Roman", serif;
		letter-spacing: -0.02em;
		line-height: 1.1;
		margin: 0 0 0.5em;
	}

	h1 {
		font-size: clamp(2.5rem, 6vw, 4.5rem);
		font-weight: 500;
	}

	h2 {
		font-size: clamp(1.8rem, 4vw, 3rem);
		font-weight: 500;
	}

	h3 {
		font-size: clamp(1.4rem, 2.5vw, 2rem);
		font-weight: 500;
	}

	p {
		margin: 0 0 1.25rem;
	}

	a {
		color: var(--accent);
		text-underline-offset: 2px;
	}

	a:hover {
		color: var(--accent-soft);
	}

	a:focus-visible,
	button:focus-visible {
		outline: 2px solid color-mix(in srgb, var(--accent) 65%, black);
		outline-offset: 3px;
		border-radius: 4px;
	}

	img {
		max-width: 100%;
		height: auto;
	}

	code,
	pre {
		font-family: "SFMono-Regular", Menlo, Monaco, Consolas, "Liberation Mono", "Courier New", monospace;
	}

	code {
		font-size: 0.92em;
		padding: 0.16em 0.35em;
		border-radius: 6px;
		background: rgba(255, 255, 255, 0.68);
		overflow-wrap: anywhere;
	}

	pre {
		overflow-x: auto;
		padding: 1rem;
		border-radius: var(--radius-md);
		background: #221f1a;
		color: #f0ede6;
	}

	pre code {
		background: transparent;
		padding: 0;
		color: inherit;
	}

	.page-intro {
		margin-bottom: clamp(48px, 8vw, 84px);
		padding: 24px 0;
	}

	.page-intro h1 {
		font-size: clamp(3rem, 10vw, 7rem);
		line-height: 1.05;
		margin-bottom: 24px;
	}

	.page-kicker {
		font-size: 0.85rem;
		letter-spacing: 0.2em;
		text-transform: uppercase;
		color: var(--accent);
		margin-bottom: 16px;
		font-weight: 600;
	}

	.page-lead {
		font-size: clamp(1.1rem, 2vw, 1.4rem);
		max-width: 55ch;
		color: var(--muted);
		line-height: 1.6;
	}

	.breadcrumbs {
		display: flex;
		flex-wrap: wrap;
		gap: 7px;
		align-items: center;
		font-size: 0.75rem;
		letter-spacing: 0.12em;
		text-transform: uppercase;
		color: var(--muted);
		margin: 0 0 12px;
	}

	.breadcrumbs a {
		color: inherit;
		text-decoration: none;
		border-bottom: 1px solid transparent;
	}

	.breadcrumbs a:hover,
	.breadcrumbs a:focus-visible {
		border-bottom-color: currentColor;
	}

	.section-block {
		margin-top: clamp(32px, 5vw, 56px);
	}

	.section-head {
		display: flex;
		justify-content: space-between;
		gap: 16px 24px;
		flex-wrap: wrap;
		align-items: flex-end;
		margin-bottom: 24px;
	}

	.section-head h2,
	.section-head h3 {
		margin-bottom: 0;
	}

	.mag-grid {
		display: grid;
		grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
		gap: 24px;
	}

	.mag-list {
		display: grid;
		grid-template-columns: repeat(auto-fill, minmax(320px, 1fr));
		gap: 24px;
	}

	.photo-card,
	.post-card {
		display: flex;
		flex-direction: column;
		background: color-mix(in srgb, var(--paper) 60%, transparent);
		border: 1px solid color-mix(in srgb, var(--line) 40%, transparent);
		border-radius: var(--radius-lg);
		padding: 16px;
		text-decoration: none;
		color: inherit;
		transition: transform 0.4s cubic-bezier(0.165, 0.84, 0.44, 1), box-shadow 0.4s cubic-bezier(0.165, 0.84, 0.44, 1), border-color 0.4s ease, background-color 0.4s ease;
		backdrop-filter: blur(8px);
		-webkit-backdrop-filter: blur(8px);
	}

	.photo-card:hover,
	.post-card:hover {
		transform: translateY(-4px);
		box-shadow: var(--shadow-soft);
		border-color: color-mix(in srgb, var(--line) 80%, var(--accent) 20%);
		background: color-mix(in srgb, var(--paper) 95%, transparent);
	}

	.photo-card img {
		width: 100%;
		aspect-ratio: 4 / 3;
		object-fit: cover;
		border-radius: var(--radius-md);
		display: block;
		transition: transform 0.6s cubic-bezier(0.165, 0.84, 0.44, 1);
	}

	.photo-card:hover img {
		transform: scale(1.02);
	}

	.photo-card-img-wrapper {
		overflow: hidden;
		border-radius: var(--radius-md);
	}

	.photo-card-title,
	.post-card-title {
		display: block;
		margin-top: 16px;
		font-family: "Fraunces", "Times New Roman", serif;
		font-size: 1.25rem;
		line-height: 1.2;
		font-weight: 500;
	}

	.post-card-title a {
		color: inherit;
		text-decoration: none;
	}

	.post-card-title a:hover,
	.post-card-title a:focus-visible {
		text-decoration: underline;
	}

	.meta-line {
		display: flex;
		flex-wrap: wrap;
		gap: 8px 12px;
		align-items: center;
		color: var(--muted);
		font-size: 0.88rem;
	}

	.chip-row {
		display: flex;
		flex-wrap: wrap;
		gap: 8px;
	}

	.chip {
		display: inline-flex;
		align-items: center;
		padding: 6px 10px;
		font-size: 0.74rem;
		line-height: 1;
		letter-spacing: 0.08em;
		text-transform: uppercase;
		border: 1px solid var(--line);
		border-radius: 999px;
		text-decoration: none;
		color: var(--muted);
		background: rgba(255, 255, 255, 0.46);
		transition: border-color 0.2s ease, color 0.2s ease, background-color 0.2s ease;
	}

	.chip:hover,
	.chip:focus-visible {
		border-color: color-mix(in srgb, var(--line) 58%, var(--accent) 42%);
		color: var(--ink);
		outline: none;
	}

	.chip.is-current {
		border-color: color-mix(in srgb, var(--line) 55%, var(--accent) 45%);
		color: var(--ink);
		background: rgba(255, 255, 255, 0.72);
	}

	.chip.is-disabled {
		opacity: 0.5;
		pointer-events: none;
	}

	.pager {
		display: flex;
		flex-wrap: wrap;
		gap: 10px;
		align-items: center;
	}

	.card-panel {
		background: color-mix(in srgb, var(--paper) 84%, white);
		border: 1px solid var(--line);
		border-radius: var(--radius-lg);
		padding: clamp(15px, 2.4vw, 23px);
	}

	.prose {
		max-width: 72ch;
	}

	.prose > :last-child {
		margin-bottom: 0;
	}

	.prose :where(h2, h3, h4) {
		margin-top: 1.4em;
	}

	.prose :where(ul, ol) {
		padding-left: 1.2rem;
	}

	.prose :where(li + li) {
		margin-top: 0.45rem;
	}

	.prose blockquote {
		margin: 1.3rem 0;
		padding: 0.5rem 0 0.5rem 1rem;
		border-left: 3px solid color-mix(in srgb, var(--line) 62%, var(--accent) 38%);
		color: var(--muted);
	}

	.prose img {
		border-radius: var(--radius-md);
	}

	[data-animate] {
		animation: fade-up 0.62s ease both;
	}

	@keyframes fade-up {
		from {
			opacity: 0;
			transform: translateY(6px);
		}
		to {
			opacity: 1;
			transform: translateY(0);
		}
	}

	@media (max-width: 720px) {
		.site-footer {
			flex-direction: column;
		}
	}
</style>
