---
interface Props {
	pageTitle?: string;
	description?: string;
}

const {
	pageTitle = "d0lfin photo blog",
	description = "Photo-first personal site with occasional blog notes.",
} = Astro.props;
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="icon" href="/favicon.ico" />
		<meta name="generator" content={Astro.generator} />
		<meta name="description" content={description} />
		<title>{pageTitle}</title>
	</head>
	<body>
		<main>
			<slot />
		</main>
	</body>
</html>

<style>
	:root {
		font-family: "Avenir Next", "Segoe UI", sans-serif;
		color: #111827;
		background: #f8fafc;
	}

	html, body {
		margin: 0;
		width: 100%;
	}

	main {
		max-width: 960px;
		margin: 0 auto;
		padding: 24px 18px 48px;
	}
</style>
