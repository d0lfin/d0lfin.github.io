---
import Layout from "../layouts/Layout.astro";
---

<Layout
  pageTitle="404 | Alexey Emelin"
  description="Requested page was not found."
  canonicalPath="/404/"
  noIndex={true}
>
  <section class="page-intro card-panel" data-animate>
    <p class="breadcrumbs">
      <a href="/">Home</a>
      <span>/</span>
      <span>404</span>
    </p>
    <p class="page-kicker">Not Found</p>
    <h1>404</h1>
    <p class="page-lead">The page does not exist or has been moved.</p>
    <p><a class="chip" href="/">Go to home</a></p>
  </section>
</Layout>
