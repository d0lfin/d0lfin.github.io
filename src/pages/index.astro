---
import { getCollection } from "astro:content";
import Layout from "../layouts/Layout.astro";
import { getAllPhotos } from "../lib/photos";

const photos = getAllPhotos();
const posts = (await getCollection("blog", ({ data }) => !data.draft)).sort(
	(a, b) => b.data.date.getTime() - a.data.date.getTime(),
);
---

<Layout pageTitle="Home | d0lfin photo blog">
	<h1>d0lfin photo blog</h1>
	<p>Drop files into <code>public/photos/...</code> and they are published automatically.</p>
	<p><a href="/gallery/">Open gallery</a></p>

	<section>
		<h2>Latest Photos</h2>
		<ul>
			{
				photos.slice(0, 8).map((photo) => (
					<li>
						<a href={`/photo/${photo.slug}/`}>{photo.title}</a>
						{" • "}
						<small>{photo.capturedAt ? photo.capturedAt.slice(0, 10) : photo.relativePath}</small>
						{" • "}
						<small><a href={`/gallery/${photo.seriesSlug}/`}>{photo.seriesLabel}</a></small>
					</li>
				))
			}
		</ul>
	</section>

	<section>
		<h2>Latest Blog Notes</h2>
		<ul>
			{
				posts.map((post) => (
					<li>
						<a href={`/blog/${post.slug}/`}>{post.data.title}</a>
						{" • "}
						<small>{post.data.date.toISOString().slice(0, 10)}</small>
					</li>
				))
			}
		</ul>
	</section>
</Layout>
