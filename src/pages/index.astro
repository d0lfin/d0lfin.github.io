---
import { getCollection } from "astro:content";
import Layout from "../layouts/Layout.astro";
import { getAllPhotos } from "../lib/photos";

const photos = getAllPhotos();
const posts = (await getCollection("blog", ({ data }) => !data.draft)).sort(
	(a, b) => b.data.date.getTime() - a.data.date.getTime(),
);
---

<Layout pageTitle="Home | Alexey Emelin" canonicalPath="/">
	<section class="page-intro" data-animate>
		<p class="page-kicker">Photographer & Developer</p>
		<h1>Visuals &<br/>Thoughts.</h1>
		<p class="page-lead">
			A curated archive of moments and short notes, published straight from the repository with minimal ceremony.
		</p>
		<p class="meta-line">
			<a href="/gallery/" class="chip">Open gallery archive</a>
			<a href="/blog/" class="chip">Read the journal</a>
		</p>
	</section>

	<section class="section-block" data-animate>
		<div class="section-head">
			<h2>Latest In Gallery</h2>
			<p class="meta-line"><span>{photos.length}</span><span>items</span></p>
		</div>
		<div class="mag-grid">
			{
				photos.slice(0, 10).map((photo) => (
					<a class="photo-card" href={`/photo/${photo.slug}/`}>
						<div class="photo-card-img-wrapper">
							<img
								src={photo.previewSrc ?? photo.src}
								alt={photo.description ?? photo.title}
								loading="lazy"
								decoding="async"
							/>
						</div>
						<span class="photo-card-title">{photo.title}</span>
						<span class="meta-line">
							<span>{photo.capturedAt ? photo.capturedAt.slice(0, 10) : photo.relativePath}</span>
							<span>•</span>
							<span>{photo.seriesLabel}</span>
						</span>
					</a>
				))
			}
		</div>
	</section>

	<section class="section-block" data-animate>
		<div class="section-head">
			<h2>Latest Journal Entries</h2>
			<p class="meta-line"><a href="/blog/">Open full journal</a></p>
		</div>
		<div class="mag-list">
			{
				posts.slice(0, 4).map((post) => (
					<article class="post-card">
						<h3 class="post-card-title">
							<a href={`/blog/${post.slug}/`}>{post.data.title}</a>
						</h3>
						<p class="meta-line">
							<span>{post.data.date.toISOString().slice(0, 10)}</span>
							<span>•</span>
							<span>{post.data.tags.join(", ")}</span>
						</p>
						<p>{post.data.summary}</p>
					</article>
				))
			}
		</div>
	</section>
</Layout>
