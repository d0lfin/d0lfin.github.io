---
import Layout from "../../layouts/Layout.astro";
import { getAllPhotos, getSeriesList } from "../../lib/photos";

const photos = getAllPhotos();
const seriesList = getSeriesList(photos);
---

<Layout
  pageTitle="Gallery | Alexey Emelin"
  description="Visual archive grouped by series."
  canonicalPath="/gallery/"
>
  <section class="page-intro" data-animate>
    <p class="breadcrumbs">
      <a href="/">Home</a>
      <span>/</span>
      <span>Gallery</span>
    </p>
    <p class="page-kicker">Archive</p>
    <h1>Gallery</h1>
    <p class="page-lead">
      A clean visual index grouped by series. Each item opens on its own page with metadata and original download.
    </p>
    <div class="chip-row">
      {seriesList.map((series) => (
        <a class="chip" href={`/gallery/${series.slug}/`}>
          {series.label} ({series.count})
        </a>
      ))}
    </div>
  </section>

  <section class="section-block" data-animate>
    <div class="section-head">
      <h2>Recently Added</h2>
      <p class="meta-line"><span>{photos.length}</span><span>items in total</span></p>
    </div>
    <div class="mag-grid">
      {photos.slice(0, 24).map((photo) => (
        <a class="photo-card" href={`/photo/${photo.slug}/`}>
          <div class="photo-card-img-wrapper">
            <img
              src={photo.previewSrc ?? photo.src}
              alt={photo.description ?? photo.title}
              loading="lazy"
              decoding="async"
            />
          </div>
          <span class="photo-card-title">{photo.title}</span>
          <span class="meta-line">
            <span>{photo.seriesLabel}</span>
            <span>•</span>
            <span>{photo.capturedAt ? photo.capturedAt.slice(0, 10) : photo.relativePath}</span>
          </span>
        </a>
      ))}
    </div>
  </section>

  <section class="section-block" data-animate>
    <div class="section-head">
      <h2>Series</h2>
      <p class="meta-line">Open a dedicated stream</p>
    </div>
    <div class="mag-grid">
      {seriesList.map((series) => (
        <a class="photo-card" href={`/gallery/${series.slug}/`}>
          <div class="photo-card-img-wrapper">
            <img
              src={series.coverPhoto.previewSrc ?? series.coverPhoto.src}
              alt={series.coverPhoto.description ?? series.label}
              loading="lazy"
              decoding="async"
            />
          </div>
          <span class="photo-card-title">{series.label}</span>
          <span class="meta-line">
            <span>{series.count} items</span>
            <span>•</span>
            <span>Open series</span>
          </span>
        </a>
      ))}
    </div>
  </section>
</Layout>
