---
import Layout from "../../layouts/Layout.astro";
import { getAllPhotos, getSeriesList } from "../../lib/photos";

export async function getStaticPaths() {
  const photos = getAllPhotos();
  const seriesList = getSeriesList(photos);
  return seriesList.map((series) => ({
    params: { series: series.slug },
    props: { series },
  }));
}

const { series } = Astro.props;
const allPhotos = getAllPhotos();
const seriesList = getSeriesList(allPhotos);
const photos = allPhotos.filter((photo) => photo.seriesSlug === series.slug);
---

<Layout
  pageTitle={`${series.label} | Gallery | Alexey Emelin`}
  description={`${series.count} items in ${series.label}.`}
  canonicalPath={`/gallery/${series.slug}/`}
>
  <section class="page-intro" data-animate>
    <p class="breadcrumbs">
      <a href="/">Home</a>
      <span>/</span>
      <a href="/gallery/">Gallery</a>
      <span>/</span>
      <span>{series.label}</span>
    </p>
    <p class="page-kicker">Series</p>
    <h1>{series.label}</h1>
    <p class="page-lead">{series.count} item(s) in this series.</p>
    <div class="chip-row">
      {seriesList.map((item) => (
        <a class={`chip ${item.slug === series.slug ? "is-current" : ""}`} href={`/gallery/${item.slug}/`}>
          {item.label}
        </a>
      ))}
    </div>
  </section>

  <section class="section-block" data-animate>
    <div class="section-head">
      <h2>All Items</h2>
      <p class="meta-line"><a href="/gallery/">Back to all series</a></p>
    </div>
    <div class="mag-grid">
      {photos.map((photo) => (
        <a class="photo-card" href={`/photo/${photo.slug}/`}>
          <div class="photo-card-img-wrapper">
            <img
              src={photo.previewSrc ?? photo.src}
              alt={photo.description ?? photo.title}
              loading="lazy"
              decoding="async"
            />
          </div>
          <span class="photo-card-title">{photo.title}</span>
          <span class="meta-line">
            <span>{photo.capturedAt ? photo.capturedAt.slice(0, 10) : photo.relativePath}</span>
          </span>
        </a>
      ))}
    </div>
  </section>
</Layout>
