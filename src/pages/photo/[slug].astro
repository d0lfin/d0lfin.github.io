---
import { getAllPhotos } from "../../lib/photos";
import Layout from "../../layouts/Layout.astro";

export async function getStaticPaths() {
  const photos = getAllPhotos();
  return photos.map((entry) => ({
    params: { slug: entry.slug },
    props: { photo: entry },
  }));
}

const { photo } = Astro.props;
const photos = getAllPhotos();
const currentIndex = photos.findIndex((item) => item.slug === photo.slug);
const newerPhoto = currentIndex > 0 ? photos[currentIndex - 1] : undefined;
const olderPhoto = currentIndex >= 0 && currentIndex < photos.length - 1 ? photos[currentIndex + 1] : undefined;
const cameraLabel = [photo.cameraMake, photo.cameraModel].filter(Boolean).join(" ");
const hasExifMetadata = Boolean(photo.capturedAt || cameraLabel || photo.lensModel);
---

<Layout pageTitle={`${photo.title} | Photo`}>
  <p>
    <a href="/">Home</a>
    {" • "}
    <a href="/gallery/">Gallery</a>
    {" • "}
    <a href={`/gallery/${photo.seriesSlug}/`}>{photo.seriesLabel}</a>
  </p>
  <h1>{photo.title}</h1>
  <p>{photo.relativePath}</p>
  {hasExifMetadata && (
    <ul>
      {photo.capturedAt && <li>Taken: {photo.capturedAt.slice(0, 10)}</li>}
      {cameraLabel && <li>Camera: {cameraLabel}</li>}
      {photo.lensModel && <li>Lens: {photo.lensModel}</li>}
    </ul>
  )}

  <figure>
    <a href={photo.src} target="_blank" rel="noreferrer">
      <img
        src={photo.previewSrc ?? photo.src}
        alt={photo.description ?? photo.title}
        loading="eager"
        decoding="async"
      />
    </a>
  </figure>

  {photo.description && <p>{photo.description}</p>}
  <p>
    <a href={photo.src} download>Download original</a>
    {" • "}
    <a href={photo.src} target="_blank" rel="noreferrer">Open original</a>
  </p>

  <nav class="pager">
    <span>{newerPhoto ? <a href={`/photo/${newerPhoto.slug}/`}>← Newer</a> : "← Newer"}</span>
    <span>{olderPhoto ? <a href={`/photo/${olderPhoto.slug}/`}>Older →</a> : "Older →"}</span>
  </nav>
</Layout>

<style>
  figure {
    margin: 0 0 16px;
  }

  img {
    width: 100%;
    max-width: 900px;
    border-radius: 10px;
    display: block;
  }

  .pager {
    margin-top: 28px;
    display: flex;
    justify-content: space-between;
    gap: 12px;
  }
</style>
