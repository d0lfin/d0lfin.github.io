---
import { getAllPhotos } from "../../lib/photos";
import Layout from "../../layouts/Layout.astro";

export async function getStaticPaths() {
  const photos = getAllPhotos();
  return photos.map((entry) => ({
    params: { slug: entry.slug },
    props: { photo: entry },
  }));
}

const { photo } = Astro.props;
---

<Layout pageTitle={`${photo.title} | Photo`}>
  <p><a href="/">Home</a></p>
  <h1>{photo.title}</h1>
  <p>{photo.relativePath}</p>

  <figure>
    <img src={photo.src} alt={photo.description ?? photo.title} loading="eager" decoding="async" />
  </figure>

  {photo.description && <p>{photo.description}</p>}
</Layout>

<style>
  figure {
    margin: 0 0 16px;
  }

  img {
    width: 100%;
    max-width: 900px;
    border-radius: 10px;
    display: block;
  }

  figcaption {
    margin-top: 8px;
    color: #374151;
  }
</style>
