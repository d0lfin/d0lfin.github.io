---
import { getAllPhotos } from "../../lib/photos";
import Layout from "../../layouts/Layout.astro";

export async function getStaticPaths() {
  const photos = getAllPhotos();
  return photos.map((entry) => ({
    params: { slug: entry.slug },
    props: { photo: entry },
  }));
}

function formatCapturedAt(value?: string): string | undefined {
  if (!value) {
    return undefined;
  }
  const date = new Date(value);
  if (Number.isNaN(date.getTime())) {
    return value.slice(0, 10);
  }
  return new Intl.DateTimeFormat("en-US", {
    year: "numeric",
    month: "long",
    day: "numeric",
  }).format(date);
}

const { photo } = Astro.props;
const photos = getAllPhotos();
const currentIndex = photos.findIndex((item) => item.slug === photo.slug);
const newerPhoto = currentIndex > 0 ? photos[currentIndex - 1] : undefined;
const olderPhoto =
  currentIndex >= 0 && currentIndex < photos.length - 1 ? photos[currentIndex + 1] : undefined;

const cameraLabel = [photo.cameraMake, photo.cameraModel].filter(Boolean).join(" ");
const capturedAtLabel = formatCapturedAt(photo.capturedAt);
const metadata = [
  { label: "Captured", value: capturedAtLabel },
  { label: "Camera", value: cameraLabel },
  { label: "Lens", value: photo.lensModel },
  { label: "File", value: photo.relativePath },
].filter((item) => Boolean(item.value));
---

<Layout
  pageTitle={`${photo.title} | Gallery | Alexey Emelin`}
  description={photo.description ?? `${photo.seriesLabel} entry`}
  canonicalPath={`/photo/${photo.slug}/`}
  ogImage={photo.previewSrc ?? photo.src}
  ogType="article"
>
  <article>
    <section class="page-intro card-panel" data-animate>
      <p class="breadcrumbs">
        <a href="/">Home</a>
        <span>/</span>
        <a href="/gallery/">Gallery</a>
        <span>/</span>
        <a href={`/gallery/${photo.seriesSlug}/`}>{photo.seriesLabel}</a>
      </p>
      <p class="page-kicker">Entry</p>
      <h1>{photo.title}</h1>
      <p class="page-lead">{photo.description ?? ""}</p>
      {metadata.length > 0 && (
        <dl class="meta-table">
          {metadata.map((item) => (
            <>
              <dt>{item.label}</dt>
              <dd>{item.value}</dd>
            </>
          ))}
        </dl>
      )}
    </section>

    <figure class="photo-frame card-panel" data-animate>
      <a href={photo.src} target="_blank" rel="noreferrer" aria-label="Open original file in new tab">
        <img
          src={photo.previewSrc ?? photo.src}
          alt={photo.description ?? photo.title}
          loading="eager"
          decoding="async"
        />
      </a>
      <figcaption class="meta-line">
        <a href={photo.src} download>Download original</a>
        <span>•</span>
        <a href={photo.src} target="_blank" rel="noreferrer">Open full size</a>
      </figcaption>
    </figure>

    <nav class="pager" data-animate aria-label="Photo navigation">
      {newerPhoto ? (
        <a class="chip" href={`/photo/${newerPhoto.slug}/`}>← Newer</a>
      ) : (
        <span class="chip is-disabled">← Newer</span>
      )}
      {olderPhoto ? (
        <a class="chip" href={`/photo/${olderPhoto.slug}/`}>Older →</a>
      ) : (
        <span class="chip is-disabled">Older →</span>
      )}
    </nav>
  </article>
</Layout>

<style>
  .photo-frame {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 16px;
    padding: 24px;
    background: transparent;
    border: none;
    box-shadow: none;
  }

  .photo-frame img {
    width: 100%;
    max-height: min(88vh, 1000px);
    object-fit: contain;
    border-radius: var(--radius-lg);
    display: block;
    box-shadow: var(--shadow-soft);
  }

  .meta-table {
    margin: 12px 0 0;
    display: grid;
    grid-template-columns: minmax(80px, 120px) 1fr;
    gap: 6px 12px;
    align-items: baseline;
    font-size: 0.9rem;
  }

  .meta-table dt {
    color: var(--muted);
    text-transform: uppercase;
    letter-spacing: 0.08em;
    font-size: 0.72rem;
    margin: 0;
  }

  .meta-table dd {
    margin: 0;
    overflow-wrap: anywhere;
  }

  @media (max-width: 640px) {
    .meta-table {
      grid-template-columns: 1fr;
      gap: 2px;
    }
  }
</style>
