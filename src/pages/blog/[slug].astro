---
import { getCollection } from "astro:content";
import Layout from "../../layouts/Layout.astro";
import { toTagSlug } from "../../lib/blog";

export async function getStaticPaths() {
  const posts = await getCollection("blog", ({ data }) => !data.draft);
  return posts.map((entry) => ({
    params: { slug: entry.slug },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const { Content } = await entry.render();
---

<Layout
  pageTitle={`${entry.data.title} | Journal | Alexey Emelin`}
  description={entry.data.summary}
  canonicalPath={`/blog/${entry.slug}/`}
  ogImage={entry.data.hero}
  ogType="article"
>
  <article>
    <section class="page-intro card-panel" data-animate>
      <p class="breadcrumbs">
        <a href="/">Home</a>
        <span>/</span>
        <a href="/blog/">Journal</a>
      </p>
      <p class="page-kicker">Entry</p>
      <h1>{entry.data.title}</h1>
      <p class="page-lead">{entry.data.summary}</p>
      <p class="meta-line">
        <span>{entry.data.date.toISOString().slice(0, 10)}</span>
        {entry.data.tags.length > 0 && (
          <>
            <span>•</span>
            <span>{entry.data.tags.length} tag(s)</span>
          </>
        )}
      </p>
      {entry.data.tags.length > 0 && (
        <div class="chip-row">
          {entry.data.tags.map((tag) => (
            <a class="chip" href={`/blog/tag/${toTagSlug(tag)}/`}>
              {tag}
            </a>
          ))}
        </div>
      )}
    </section>

    {entry.data.hero && (
      <figure class="post-hero card-panel" data-animate>
        <img src={entry.data.hero} alt={entry.data.title} loading="eager" decoding="async" />
      </figure>
    )}

    <section class="card-panel prose" data-animate>
      <Content />
    </section>
  </article>
</Layout>

<style>
  .post-hero {
    padding: 10px;
  }

  .post-hero img {
    width: 100%;
    border-radius: var(--radius-md);
    display: block;
  }
</style>
