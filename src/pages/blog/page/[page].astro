---
import Layout from "../../../layouts/Layout.astro";
import {
  getBlogPageUrl,
  getPublishedPosts,
  getTagGroups,
  paginatePosts,
  toTagSlug,
} from "../../../lib/blog";

export async function getStaticPaths() {
  const posts = await getPublishedPosts();
  const pages = paginatePosts(posts).filter((page) => page.page > 1);
  return pages.map((pageData) => ({
    params: { page: String(pageData.page) },
    props: { pageData },
  }));
}

const { pageData } = Astro.props;
const tags = getTagGroups(await getPublishedPosts());
---

<Layout
  pageTitle={`Journal Page ${pageData.page} | Alexey Emelin`}
  description={`Journal page ${pageData.page}`}
  canonicalPath={getBlogPageUrl(pageData.page)}
>
  <section class="page-intro card-panel" data-animate>
    <p class="breadcrumbs">
      <a href="/">Home</a>
      <span>/</span>
      <a href="/blog/">Journal</a>
      <span>/</span>
      <span>Page {pageData.page}</span>
    </p>
    <p class="page-kicker">Journal</p>
    <h1>Notes</h1>
    <p class="page-lead">Page {pageData.page} of {pageData.totalPages}.</p>
    {tags.length > 0 && (
      <div class="chip-row">
        {tags.map((tag) => (
          <a class="chip" href={`/blog/tag/${tag.slug}/`}>
            {tag.label}
          </a>
        ))}
      </div>
    )}
  </section>

  <section class="section-block" data-animate>
    <div class="mag-list">
      {pageData.items.map((post) => (
        <article class="post-card">
          <h2 class="post-card-title">
            <a href={`/blog/${post.slug}/`}>{post.data.title}</a>
          </h2>
          <p class="meta-line">
            <span>{post.data.date.toISOString().slice(0, 10)}</span>
            <span>•</span>
            <span>{post.data.tags.length} tag(s)</span>
          </p>
          <p>{post.data.summary}</p>
          {post.data.tags.length > 0 && (
            <p class="chip-row">
              {post.data.tags.map((tag) => (
                <a class="chip" href={`/blog/tag/${toTagSlug(tag)}/`}>
                  {tag}
                </a>
              ))}
            </p>
          )}
        </article>
      ))}
    </div>
  </section>

  <nav class="pager" data-animate aria-label="Journal pages">
    {Array.from({ length: pageData.totalPages }, (_, index) => index + 1).map((page) =>
      page === pageData.page ? (
        <span class="chip is-current">{page}</span>
      ) : (
        <a class="chip" href={getBlogPageUrl(page)}>{page}</a>
      ),
    )}
  </nav>
</Layout>
