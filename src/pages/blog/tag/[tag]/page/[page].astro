---
import Layout from "../../../../../layouts/Layout.astro";
import { getPublishedPosts, getTagGroups, getTagPageUrl, paginatePosts } from "../../../../../lib/blog";

export async function getStaticPaths() {
  const posts = await getPublishedPosts();
  const groups = getTagGroups(posts);
  const paths = [];

  for (const group of groups) {
    const pages = paginatePosts(group.posts).filter((pageData) => pageData.page > 1);
    for (const pageData of pages) {
      paths.push({
        params: {
          tag: group.slug,
          page: String(pageData.page),
        },
        props: {
          tagSlug: group.slug,
          tagLabel: group.label,
          pageData,
        },
      });
    }
  }

  return paths;
}

const { tagSlug, tagLabel, pageData } = Astro.props;
---

<Layout
  pageTitle={`${tagLabel} Page ${pageData.page} | Journal Tag | Alexey Emelin`}
  description={`Entries tagged ${tagLabel}, page ${pageData.page}.`}
  canonicalPath={getTagPageUrl(tagSlug, pageData.page)}
>
  <section class="page-intro card-panel" data-animate>
    <p class="breadcrumbs">
      <a href="/">Home</a>
      <span>/</span>
      <a href="/blog/">Journal</a>
      <span>/</span>
      <a href={`/blog/tag/${tagSlug}/`}>{tagLabel}</a>
      <span>/</span>
      <span>Page {pageData.page}</span>
    </p>
    <p class="page-kicker">Tag</p>
    <h1>{tagLabel}</h1>
    <p class="page-lead">Page {pageData.page} of {pageData.totalPages}.</p>
  </section>

  <section class="section-block" data-animate>
    <div class="mag-list">
      {pageData.items.map((post) => (
        <article class="post-card">
          <h2 class="post-card-title">
            <a href={`/blog/${post.slug}/`}>{post.data.title}</a>
          </h2>
          <p class="meta-line">
            <span>{post.data.date.toISOString().slice(0, 10)}</span>
          </p>
          <p>{post.data.summary}</p>
        </article>
      ))}
    </div>
  </section>

  <nav class="pager" data-animate aria-label="Tag pages">
    {Array.from({ length: pageData.totalPages }, (_, index) => index + 1).map((page) =>
      page === pageData.page ? (
        <span class="chip is-current">{page}</span>
      ) : (
        <a class="chip" href={getTagPageUrl(tagSlug, page)}>{page}</a>
      ),
    )}
  </nav>
</Layout>
