---
import Layout from "../../../../layouts/Layout.astro";
import { getPublishedPosts, getTagGroups, getTagPageUrl, paginatePosts } from "../../../../lib/blog";

export async function getStaticPaths() {
  const posts = await getPublishedPosts();
  const groups = getTagGroups(posts);

  return groups.map((group) => {
    const pageData = paginatePosts(group.posts)[0];
    return {
      params: { tag: group.slug },
      props: {
        tagSlug: group.slug,
        tagLabel: group.label,
        totalEntries: group.posts.length,
        pageData,
      },
    };
  });
}

const { tagSlug, tagLabel, totalEntries, pageData } = Astro.props;
---

<Layout
  pageTitle={`${tagLabel} | Journal Tag | Alexey Emelin`}
  description={`Entries tagged ${tagLabel}.`}
  canonicalPath={`/blog/tag/${tagSlug}/`}
>
  <section class="page-intro card-panel" data-animate>
    <p class="breadcrumbs">
      <a href="/">Home</a>
      <span>/</span>
      <a href="/blog/">Journal</a>
      <span>/</span>
      <span>{tagLabel}</span>
    </p>
    <p class="page-kicker">Tag</p>
    <h1>{tagLabel}</h1>
    <p class="page-lead">{totalEntries} entry(s) with this tag.</p>
  </section>

  <section class="section-block" data-animate>
    <div class="mag-list">
      {pageData.items.map((post) => (
        <article class="post-card">
          <h2 class="post-card-title">
            <a href={`/blog/${post.slug}/`}>{post.data.title}</a>
          </h2>
          <p class="meta-line">
            <span>{post.data.date.toISOString().slice(0, 10)}</span>
          </p>
          <p>{post.data.summary}</p>
        </article>
      ))}
    </div>
  </section>

  {pageData.totalPages > 1 && (
    <nav class="pager" data-animate aria-label="Tag pages">
      {Array.from({ length: pageData.totalPages }, (_, index) => index + 1).map((number) =>
        number === pageData.page ? (
          <span class="chip is-current">{number}</span>
        ) : (
          <a class="chip" href={getTagPageUrl(tagSlug, number)}>{number}</a>
        ),
      )}
    </nav>
  )}
</Layout>
